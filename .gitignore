# Large fine-tuned model weights (~965M; regenerate via training, kept on disk)
/models/*.bin
# FAISS datastores (~254M; rebuildable from model + training set on a GPU)
results/**/datastore/
# Saved-model checkpoints from fine-tuning
saved_models/
**/checkpoint-best-acc/

# Redundant dataset archives (extracted *.jsonl/*.txt are the source of truth)
*.zip

# Python caches
__pycache__/
*.pyc
.ipynb_checkpoints/

# Reproduction-harness caches & logs (regenerated by kNN-Prediction/reproduce_results.py)
kNN-Prediction/out_*.npz
kNN-Prediction/*.log

# OS cruft
.DS_Store
**/__MACOSX/
kNN-Prediction/patch_results_*.json

# Slide builder deps / caches
presentation/node_modules/
presentation/_ql/
